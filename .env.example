# G.A.T.E. Olympiad — example environment
# Copy to .env.local and fill in real values.

# Database (Neon) — pooled connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/db?sslmode=require"

# Email (Resend) — https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="G.A.T.E. Olympiad <noreply@example.com>"

# Better Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
